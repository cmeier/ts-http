{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "composite": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "paths": {
            "@ts-http/core": [
                "./packages/core/src/index.ts"
            ],
            "@ts-http/express": [
                "./packages/express/src/index.ts"
            ],
            "@ts-http/nestjs": [
                "./packages/nestjs/src/index.ts"
            ],
            "@ts-http/openapi": [
                "./packages/openapi/src/index.ts"
            ]
        }
    }
}